# LocaleRent example environment variables

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=anon-key-placeholder
SUPABASE_SERVICE_ROLE_KEY=service-role-key-placeholder

# SMTP (used for magic links / notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=super-secret-placeholder

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Stripe & other services (add if used)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# Add other env variables required by your setup below
